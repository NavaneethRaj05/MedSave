# MedSave Server Environment Variables
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB — local or Atlas
MONGO_URI=mongodb://localhost:27017/medsave
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/medsave

# Groq AI API Key (https://console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# CORS — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173
# FRONTEND_URL=https://medsave.vercel.app
