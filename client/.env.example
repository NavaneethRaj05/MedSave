# MedSave Client Environment Variables
# For LOCAL DEVELOPMENT: Vite proxy handles /api → localhost:5000 (no variable needed)
# For PRODUCTION VERCEL: Set VITE_API_URL to your backend URL

# Leave blank for dev (proxy handles it)
# VITE_API_URL=

# For production — set this to your deployed backend URL:
# VITE_API_URL=https://medsave-api.vercel.app/api
